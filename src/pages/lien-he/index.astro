---
import BaseLayout from '../../layouts/BaseLayout.astro';
const schema = JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ContactPage",
        "name": "Liên Hệ Công Ty Thu Mua Cáp Đồng Đức Minh",
        "description": "Thông tin liên hệ chính thức của Công ty Đức Minh để yêu cầu báo giá và dịch vụ thu mua phế liệu tận nơi tại TP.HCM và các tỉnh lân cận.",
        "url": "https://thumuacapdonggiacao.com/lien-he/",
        "mainEntity": {
          "@type": "LocalBusiness",
          "name": "Công Ty Thu Mua Cáp Đồng Đức Minh",
          "image": "https://thumuacapdonggiacao.com/img/logo.svg",
          "url": "https://thumuacapdonggiacao.com/",
          "telephone": "+84936350118",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "14 ấp 2, Đông Thạnh",
            "addressLocality": "Hóc Môn",
            "addressRegion": "TP. HCM",
            "addressCountry": "VN"
          },
          "openingHoursSpecification": {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday",
              "Saturday",
              "Sunday"
            ],
            "opens": "06:00",
            "closes": "22:00"
          },
          "contactPoint": {
            "@type": "ContactPoint",
            "telephone": "+84-936-350-118",
            "contactType": "customer service",
            "areaServed": "VN",
            "availableLanguage": "Vietnamese"
          }
        }
      });
---
<BaseLayout 
  title="Liên Hệ Đức Minh [0936.350.118] - Báo Giá Thu Mua Phế Liệu Cao Nhất"
  description="Gọi ngay 0936.350.118 (Zalo) để nhận báo giá thu mua phế liệu đồng, nhôm, inox, cáp điện, pin mặt trời... giá cao nhất TP.HCM. Công ty Đức Minh cam kết khảo sát tận nơi miễn phí, thu mua nhanh chóng, thanh toán liền tay."
  canonical="https://thumuacapdonggiacao.com/lien-he/"
  schema={schema}
>
<main>
<section id="contact-page">
<div class="container">
<h1 class="section-title">Kết Nối Với Đức Minh</h1>
<p class="section-subtitle">
            Chúng tôi luôn sẵn sàng lắng nghe và hỗ trợ bạn 24/7. Hãy liên hệ
            ngay để nhận được tư vấn và báo giá tốt nhất!
          </p>
<div class="contact-grid">
<div class="contact-details">
<h3>Thông Tin Liên Hệ Trực Tiếp</h3>
<p style="margin-bottom: 30px">
                Dù yêu cầu của bạn lớn hay nhỏ, đừng ngần ngại kết nối với chúng
                tôi. Đội ngũ Đức Minh cam kết phản hồi nhanh chóng và tận tâm.
              </p>
<div class="contact-info-item">
<div class="icon">
<svg fill="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M12 2C7.589 2 4 5.589 4 10C4 12.899 5.822 15.429 8.354 16.597L11.18 22.382C11.332 22.701 11.651 22.909 12 22.909C12.349 22.909 12.668 22.701 12.82 22.382L15.646 16.597C18.178 15.429 20 12.899 20 10C20 5.589 16.411 2 12 2ZM12 13C10.343 13 9 11.657 9 10C9 8.343 10.343 7 12 7C13.657 7 15 8.343 15 10C15 11.657 13.657 13 12 13Z"></path>
</svg>
</div>
<div>
<strong>Trụ sở chính:</strong>
<span>14 ấp 2, Đông Thạnh, Hóc Môn, TP. HCM</span>
</div>
</div>
<div class="contact-info-item">
<div class="icon">
<svg fill="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M3.513 5.234C4.984 2.902 7.713 1.512 10.512 1.512C16.223 1.512 22.488 7.777 22.488 13.488C22.488 16.287 21.098 19.016 18.766 20.487C18.595 20.589 18.406 20.641 18.216 20.641C17.954 20.641 17.697 20.516 17.514 20.297L15.181 17.525C14.908 17.199 14.945 16.712 15.271 16.439C16.324 15.553 16.923 14.347 16.923 12.986C16.923 10.158 14.029 7.796 11.013 7.796C9.652 7.796 8.446 8.395 7.56 9.448C7.287 9.774 6.801 9.811 6.474 9.538L3.702 7.205C3.484 7.022 3.359 6.765 3.359 6.503C3.359 6.332 3.411 6.164 3.513 6.012V5.234Z"></path>
</svg>
</div>
<div>
<strong>Hotline / Zalo (Mr. Đức):</strong>
<a href="tel:0936350118" style="font-size: 1.2rem; font-weight: bold">0936.350.118</a>
</div>
</div>
<div class="contact-info-item">
<div class="icon">
<svg fill="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M2.003 5.884L9.92 12.228C11.231 13.284 12.769 13.284 14.08 12.228L21.997 5.884C21.933 4.823 21.02 4 20 4H4C2.98 4 2.067 4.823 2.003 5.884ZM22 8.118L14.865 13.911C13.161 15.286 10.839 15.286 9.135 13.911L2 8.118V18C2 19.105 2.895 20 4 20H20C21.105 20 22 19.105 22 18V8.118Z"></path>
</svg>
</div>
<div>
<strong>Email:</strong>
<a href="mailto:quibinh0118@gmail.com">quibinh0118@gmail.com</a>
</div>
</div>
<div class="contact-info-item">
<div class="icon">
<svg fill="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
<path d="M12 2C6.486 2 2 6.486 2 12C2 17.514 6.486 22 12 22C17.514 22 22 17.514 22 12C22 6.486 17.514 2 12 2ZM12 20C7.589 20 4 16.411 4 12C4 7.589 7.589 4 12 4C16.411 4 20 7.589 20 12C20 16.411 16.411 20 12 20Z"></path>
<path d="M12 6L12 12 16 14"></path>
</svg>
</div>
<div>
<strong>Giờ làm việc:</strong>
<span>7:00 - 21:00 (Tất cả các ngày trong tuần)</span>
</div>
</div>
</div>
<div class="contact-form-wrapper">
<h3>Hoặc Gửi Yêu Cầu Cho Chúng Tôi</h3>
<form action="https://formspree.io/f/movpayap" class="contact-form" method="POST">
<input name="name" placeholder="Họ và Tên của bạn *" required="" type="text"/>
<input name="phone" placeholder="Số điện thoại liên hệ *" required="" type="tel"/>
<textarea name="message" placeholder="Mô tả ngắn gọn về vật tư cần Thu mua (ví dụ: cần bán 1 tấn cáp đồng, Thu mua khung sắt nhà xưởng...)*" required=""></textarea>
<button class="btn" type="submit">Gửi Yêu Cầu Báo Giá</button>
</form>
</div>
</div>
</div>
</section>
<section class="map-section" style="padding: 0">
<div class="container-fluid" style="padding: 0; max-width: 100%">
<iframe allowfullscreen="" height="450" loading="lazy" referrerpolicy="no-referrer-when-downgrade" src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d15670.804260691722!2d106.636344!3d10.910308!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3174d70677247829%3A0xab4886d2a9b58705!2zQ8OUTkcgVFkgVEhVIE1VQSBQSOG6viBMSeG7hlUgxJDhu6hDIE1JTkg!5e0!3m2!1svi!2sus!4v1761935511970!5m2!1svi!2sus" style="border: 0" title="Bản đồ chỉ đường đến Công ty Đức Minh" width="600"></iframe>
</div>
</section>
</main>
</BaseLayout>