---
import BaseLayout from '../layouts/BaseLayout.astro';
const schema = JSON.stringify([{
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "Công Ty Thu Mua Cáp Đồng Đức Minh",
        "image": "https://thumuacapdonggiacao.com/img/logo.svg",
        "url": "https://thumuacapdonggiacao.com/",
        "telephone": "0936350118",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "14 ấp 2, Đông Thạnh",
          "addressLocality": "Hóc Môn",
          "addressRegion": "TP. HCM",
          "addressCountry": "VN"
        },
        "openingHoursSpecification": {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": [
            "Monday",
            "Tuesday",
            "Wednesday",
            "Thursday",
            "Friday",
            "Saturday",
            "Sunday"
          ],
          "opens": "06:00",
          "closes": "22:00"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "10.910308",
          "longitude": "106.636344"
        },
        "areaServed": [
          { "@type": "City", "name": "Hồ Chí Minh" },
          { "@type": "City", "name": "Bình Dương" },
          { "@type": "City", "name": "Đồng Nai" },
          { "@type": "City", "name": "Long An" },
          { "@type": "AdministrativeArea", "name": "Miền Nam Việt Nam" }
        ],
        "priceRange": "$$",
        "currenciesAccepted": "VND",
        "paymentAccepted": "Cash, Bank Transfer",
        "description": "Đức Minh là đơn vị chuyên thu mua vật tư dự án năng lượng mặt trời (tấm pin, inverter), cáp đồng cũ, và dây điện phế liệu giá cao tại TP.HCM.",
        "makesOffer": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Thu Mua Pin Năng Lượng Mặt Trời",
              "description": "Chuyên thu mua, Thu mua các loại tấm pin năng lượng mặt trời đã qua sử dụng, tồn kho từ các dự án với giá cao."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Thu Mua Cáp Đồng Phế Liệu",
              "description": "Thu mua cáp đồng, dây điện cũ, vật tư điện công nghiệp tồn kho từ công trình, nhà xưởng giá cạnh tranh."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Thu Mua Phế Liệu Inox",
              "description": "Thu mua phế liệu inox các loại (304, 201, 430), vật tư inox công nghiệp cũ giá tốt."
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Thu Mua Phế Liệu Nhôm",
              "description": "Thu mua phế liệu nhôm đa dạng, bao gồm nhôm đặc, hợp kim, vụn nhôm, cửa nhôm cũ."
            }
          }
        ]
      },{
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Công ty Đức Minh thu mua cáp đồng ở đâu?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Công ty Đức Minh thu mua cáp đồng tận nơi tại TP.HCM và các tỉnh lân cận như Bình Dương, Đồng Nai, Long An. Đội xe chuyên dụng sẵn sàng đến tận công trình, nhà xưởng, khu công nghiệp để thu gom và vận chuyển."
            }
          },
          {
            "@type": "Question",
            "name": "Giá thu mua cáp đồng hiện tại là bao nhiêu?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Giá thu mua cáp đồng phế liệu dao động từ 250.000 – 350.000 VNĐ/kg tùy loại (đồng cáp, đồng đỏ, đồng vàng, đồng cháy). Để nhận báo giá chính xác nhất, vui lòng gọi Hotline 0936.350.118 để được khảo sát tận nơi miễn phí."
            }
          },
          {
            "@type": "Question",
            "name": "Đức Minh có thu mua pin năng lượng mặt trời không?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Có. Đức Minh chuyên thu mua trọn gói vật tư từ các dự án điện mặt trời bao gồm: tấm pin solar (mono, poly), biến tần (inverter), cáp DC solar, khung giàn nhôm/sắt, tủ điện và phụ kiện. Giá liên hệ theo từng lô hàng cụ thể."
            }
          },
          {
            "@type": "Question",
            "name": "Thời gian thanh toán sau khi thu mua là bao lâu?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Đức Minh cam kết thanh toán 100% ngay tại chỗ sau khi hoàn tất cân đo và kiểm định hàng hóa. Khách hàng có thể nhận tiền mặt trực tiếp hoặc chuyển khoản ngay lập tức."
            }
          },
          {
            "@type": "Question",
            "name": "Quy trình thu mua phế liệu của Đức Minh như thế nào?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Quy trình gồm 4 bước: (1) Liên hệ qua Hotline/Zalo 0936.350.118 mô tả loại và khối lượng hàng. (2) Nhân viên đến tận nơi khảo sát và báo giá miễn phí. (3) Đội xe bốc xếp, vận chuyển chuyên nghiệp. (4) Cân đo và thanh toán ngay tại chỗ."
            }
          },
          {
            "@type": "Question",
            "name": "Đức Minh có thu mua khối lượng nhỏ không?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Đức Minh thu mua mọi khối lượng, từ vài kg đến hàng chục tấn. Với lô hàng nhỏ, khách hàng có thể mang đến hoặc gửi ảnh/video qua Zalo 0936.350.118 để được báo giá trước khi đến."
            }
          }
        ]
      }]);
---
<BaseLayout 
  keywords="thu mua cáp đồng, thu mua phế liệu, giá cao, công ty đức minh, phế liệu đồng, thanh lý cáp đồng"
  title="Thu Mua Cáp Đồng Giá Cao Tận Nơi | Công Ty Đức Minh"
  description="Đức Minh thu mua cáp đồng, pin năng lượng mặt trời, phế liệu điện giá cao tận nơi TP.HCM. Thanh toán ngay, uy tín 10+ năm!"
  canonical="https://thumuacapdonggiacao.com/"
  schema={schema}
>
<main>
<section class="hero" id="hero">
<div class="slide active">
<picture>
<source media="(max-width: 768px)" srcset="
                /img/banner/banner-thu-mua-cap-dong-duc-minh-1_mobile.webp
              "/>
<img alt="Thu mua cáp đồng phế liệu các loại giá cao - Công ty Đức Minh" fetchpriority="high" height="1080" src="/img/banner/banner-thu-mua-cap-dong-duc-minh-1.webp" width="1920"/>
</picture>
</div>
<div class="slide">
<picture>
<source media="(max-width: 768px)" srcset="
                /img/banner/banner-thu-mua-cap-dong-duc-minh-2_mobile.webp
              "/>
<img alt="Dịch vụ thu mua dây điện cũ và cáp đồng tận nơi chuyên nghiệp" height="1080" loading="lazy" src="/img/banner/banner-thu-mua-cap-dong-duc-minh-2.webp" width="1920"/>
</picture>
</div>
<div class="slide">
<picture>
<source media="(max-width: 768px)" srcset="
                /img/banner/banner-thu-mua-cap-dong-duc-minh-3_mobile.webp
              "/>
<img alt="Thu mua cáp đồng và vật tư điện công nghiệp tồn kho giá tốt" height="1080" loading="lazy" src="/img/banner/banner-thu-mua-cap-dong-duc-minh-3.webp" width="1920"/>
</picture>
</div>
<div class="hero-overlay"></div>
</section>
<section class="text-banner">
<div class="container">
<h1>Thu Mua Cáp Đồng, Pin Năng Lượng Mặt Trời Giá Cao - Đức Minh</h1>
<p>
            Chuyên Thu Mua Cáp Đồng, Vật Tư Năng Lượng Mặt Trời &amp; Phế Liệu Giá
            Cao
          </p>
<a class="btn" href="tel:0936350118">Gọi ngay 0936.350.118</a>
</div>
</section>
<section id="about">
<div class="container about-grid reveal">
<div class="about-image">
<img alt="Giới thiệu Công Ty Thu Mua Cáp Đồng Đức Minh" height="500" loading="lazy" src="/img/gioi-thieu-cong-ty-thu-mua-cap-dong-duc-minh.webp" width="500"/>
</div>
<div class="about-text">
<h2>Về Công Ty Thu Mua Cáp Đồng Đức Minh</h2>
<p>
<b>ĐỨC MINH</b> là đơn vị uy tín hàng đầu trong lĩnh vực thu mua
              cáp đồng, dây điện cũ và các loại vật tư, thiết bị điện công
              nghiệp, phế liệu tồn kho từ các công trình, dự án, nhà xưởng và
              khu công nghiệp.
            </p>
<p>
              Với hơn 10 năm kinh nghiệm, chúng tôi mang đến dịch vụ thu mua tận
              nơi, chuyên nghiệp, giúp quý khách hàng giải phóng mặt bằng và thu
              hồi vốn nhanh chóng với mức giá cạnh tranh nhất thị trường.
            </p>
<ul>
<li>Thu mua tận nơi nhanh chóng, không ngại xa.</li>
<li>Đội ngũ bốc xếp, vận chuyển chuyên nghiệp.</li>
<li>Cân đo chính xác, minh bạch.</li>
<li>Thanh toán một lần ngay tại chỗ.</li>
<li>Hoa hồng cao cho người giới thiệu.</li>
</ul>
</div>
</div>
</section>
<section id="why-us" style="background: var(--bg-grey)">
<div class="container">
<h2 class="section-title">VÌ SAO CHỌN CHÚNG TÔI?</h2>
<p class="section-subtitle">
            Chúng tôi tập trung vào việc cung cấp một dịch vụ toàn diện, từ việc
            báo giá cao và cạnh tranh, đến đội ngũ bốc xếp, vận chuyển tận nơi
            chuyên nghiệp, giúp bạn giải phóng mặt bằng và thu hồi vốn một cách
            dễ dàng.
          </p>
<div class="features-grid reveal reveal-delay-1">
<div class="feature-item">
<div class="icon">💰</div>
<h3>Giá Thu Mua Cao</h3>
<p>
                Luôn đưa ra mức giá cao hơn 30% so với thị trường, đảm bảo lợi
                ích cho bạn.
              </p>
</div>
<div class="feature-item">
<div class="icon">⚖️</div>
<h3>Không Ép Giá</h3>
<p>
                Quy trình thẩm định giá rõ ràng, minh bạch, tuyệt đối không có
                tình trạng ép giá.
              </p>
</div>
<div class="feature-item">
<div class="icon">🚚</div>
<h3>Vận Chuyển Nhanh</h3>
<p>
                Có xe tải riêng, đội ngũ bốc xếp sẵn sàng đến tận nơi ngay sau
                khi thỏa thuận.
              </p>
</div>
<div class="feature-item">
<div class="icon">💵</div>
<h3>Thanh Toán Liền Tay</h3>
<p>
                Thanh toán 100% bằng tiền mặt hoặc chuyển khoản ngay sau khi cân
                hàng kết thúc.
              </p>
</div>
</div>
</div>
</section>
<section id="categories">
<div class="container">
<h2 class="section-title">THU MUA VẬT TƯ NĂNG LƯỢNG MẶT TRỜI</h2>
