---
import settings from '../data/settings.json';
// BaseLayout.astro — Layout dùng chung cho TẤT CẢ trang
// Thay đổi 1 lần ở đây = cập nhật toàn bộ 62+ trang

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  schema?: string; // JSON-LD string tuỳ chỉnh cho từng trang
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDescription,
  ogImage = 'https://thumuacapdonggiacao.com/img/banner/banner-thu-mua-cap-dong-duc-minh-1.webp',
  ogType = 'website',
  schema,
  noindex = false,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc = ogDescription ?? description;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    {Astro.url.pathname === '/' && (
      <>
        <link rel="preload" as="image" href="/img/banner/banner-thu-mua-cap-dong-duc-minh-1_mobile.webp" media="(max-width: 768px)" />
        <link rel="preload" as="image" href="/img/banner/banner-thu-mua-cap-dong-duc-minh-1.webp" media="(min-width: 769px)" />
      </>
    )}
    <meta name="description" content={description} />
    <meta name="author" content="Công Ty Đức Minh" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/img/logo.svg" type="image/svg+xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDesc} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="vi_VN" />
    <meta property="og:site_name" content="Công Ty Đức Minh" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDesc} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="theme-color" content="#e90b0b" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&family=Inter:wght@400;500;600&display=swap" /></noscript>

    <!-- Critical CSS (chống FOUC) -->
    <style>
      :root {
        --primary-color: #c90000;
        --secondary-color: #ff8c00;
        --phone-color: #d9534f;
        --zalo-color: #0068ff;
        --text-dark: #333;
        --text-light: #fff;
        --bg-light: #fff;
        --bg-grey: #f4f4f4;
        --border-color: #ddd;
      }
      html { scroll-behavior: smooth; }
      body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; background-color: #fff; margin: 0; }
    </style>

    <!-- Main CSS -->
    <link rel="stylesheet" href="/style.css?v=3" />

    <!-- Schema JSON-LD tuỳ chỉnh từng trang -->
    {schema && <Fragment set:html={`<script type="application/ld+json">${schema}</script>`} />}

    <!-- Các mã theo dõi (GA4, GTM) đã được chuyển vào CMS Settings -->

    <!-- Custom Tracking Scripts từ CMS -->
    {settings.headScripts && <Fragment set:html={settings.headScripts} />}
  </head>

  <body>
    <!-- GTM noscript -->
    <noscript>
      <iframe title="Google Tag Manager"
        src="https://www.googletagmanager.com/ns.html?id=GTM-NW8X6RD3"
        height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>

    <!-- Floating Buttons (Gọi, Zalo, Top) -->
    <div class="floating-buttons">
      <a href="#" id="goToTopBtn" class="top-float" title="Lên đầu trang" aria-label="Cuộn lên đầu trang">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
          <path fill="#FFFFFF" d="M233.4 105.4c12.5-12.5 32.8-12.5 45.3 0l192 192c12.5 12.5 12.5 32.8 0 45.3s-32.8 12.5-45.3 0L256 173.3 86.6 342.6c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3l192-192z"/>
        </svg>
      </a>
      <a href={`tel:${settings.hotline}`} class="phone-float" title="Gọi ngay" aria-label="Gọi điện thoại cho chúng tôi">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
          <path d="M164.9 24.6c-7.7-18.6-28-28.5-47.4-23.2l-88 24C12.1 30.2 0 46 0 64C0 311.4 200.6 512 448 512c18 0 33.8-12.1 38.6-29.5l24-88c5.3-19.4-4.6-39.7-23.2-47.4l-96-40c-16.3-6.8-35.2-2.1-46.3 11.6L304.7 368C234.3 334.7 177.3 277.7 144 207.3L193.3 167c13.7-11.2 18.4-30 11.6-46.3l-40-96z"/>
        </svg>
      </a>
      <a href={settings.zaloLink} class="zalo-float" target="_blank" rel="noopener noreferrer" title="Chat Zalo" aria-label="Nhắn tin Zalo">
        <svg xmlns="http://www.w3.org/2000/svg" x="0px" y="0px" viewBox="0 0 48 48">
          <path fill="#2962ff" d="M15,36V6.827l-1.211-0.811C8.64,8.083,5,13.112,5,19v10c0,7.732,6.268,14,14,14h10 c4.722,0,8.883-2.348,11.417-5.931V36H15z"></path>
          <path fill="#eee" d="M29,5H19c-1.845,0-3.601,0.366-5.214,1.014C10.453,9.25,8,14.528,8,19 c0,6.771,0.936,10.735,3.712,14.607c0.216,0.301,0.357,0.653,0.376,1.022c0.043,0.835-0.129,2.365-1.634,3.742 c-0.162,0.148-0.059,0.419,0.16,0.428c0.942,0.041,2.843-0.014,4.797-0.877c0.557-0.246,1.191-0.203,1.729,0.083 C20.453,39.764,24.333,40,28,40c4.676,0,9.339-1.04,12.417-2.916C42.038,34.799,43,32.014,43,29V19C43,11.268,36.732,5,29,5z"></path>
          <path fill="#2962ff" d="M36.75,27C34.683,27,33,25.317,33,23.25s1.683-3.75,3.75-3.75s3.75,1.683,3.75,3.75 S38.817,27,36.75,27z M36.75,21c-1.24,0-2.25,1.01-2.25,2.25s1.01,2.25,2.25,2.25S39,24.49,39,23.25S37.99,21,36.75,21z"></path>
          <path fill="#2962ff" d="M31.5,27h-1c-0.276,0-0.5-0.224-0.5-0.5V18h1.5V27z"></path>
          <path fill="#2962ff" d="M27,19.75v0.519c-0.629-0.476-1.403-0.769-2.25-0.769c-2.067,0-3.75,1.683-3.75,3.75 S22.683,27,24.75,27c0.847,0,1.621-0.293,2.25-0.769V26.5c0,0.276,0.224,0.5,0.5,0.5h1v-7.25H27z M24.75,25.5 c-1.24,0-2.25-1.01-2.25-2.25S23.51,21,24.75,21S27,22.01,27,23.25S25.99,25.5,24.75,25.5z"></path>
          <path fill="#2962ff" d="M21.25,18h-8v1.5h5.321L13,26h0.026c-0.163,0.211-0.276,0.463-0.276,0.75V27h7.5 c0.276,0,0.5-0.224,0.5-0.5v-1h-5.321L21,19h-0.026c0.163-0.211,0.276-0.463,0.276-0.75V18z"></path>
        </svg>
      </a>
    </div>

    <!-- Top Bar -->
    <div class="top-bar">
      <div class="container">
        <div class="contact-info">
          <span>📞 Hotline: <a href={`tel:${settings.hotline}`}>{settings.hotlineDisplay}</a></span> |
          <span>Zalo: <a href={settings.zaloLink}>{settings.hotlineDisplay}</a></span>
        </div>
        <div class="working-hours">Giờ làm việc: {settings.workingHours}</div>
      </div>
    </div>

    <!-- Navbar -->
    <header class="navbar">
      <div class="container">
        <a href="/" class="logo">
          <img src="/img/logo.svg" alt="Logo Công Ty Thu Mua Cáp Đồng Đức Minh" class="logo-icon" width="80" height="80" />
          <span class="logo-text">THU MUA CÁP ĐỒNG ĐỨC MINH</span>
        </a>
        <nav>
          <ul class="nav-links" id="nav-links">
            <li><a href="/">Trang Chủ</a></li>
            <li><a href="/gioi-thieu/">Giới Thiệu</a></li>
            <li class="dropdown">
              <a href="/dich-vu/">Dịch Vụ</a>
              <ul class="dropdown-menu">
                <li><a href="/dich-vu/">Tất Cả Dịch Vụ</a></li>
                <li><a href="/thu-mua-pin-nang-luong-mat-troi/">Thu Mua Pin Năng Lượng Mặt Trời</a></li>
                <li><a href="/thu-mua-cap-dong-thiet-bi-dien/">Thu Mua Cáp Đồng &amp; Thiết Bị Điện</a></li>
                <li><a href="/thu-mua-phe-lieu-cong-nghiep/">Thu Mua Phế Liệu Công Nghiệp</a></li>
                <li><a href="/thu-mua-inox/">Thu Mua Inox</a></li>
                <li><a href="/thu-mua-nhom/">Thu Mua Nhôm</a></li>
              </ul>
            </li>
            <li class="dropdown">
              <a href="#" onclick="event.preventDefault();">Khu Vực Thu Mua</a>
              <ul class="dropdown-menu">
                <li><a href="/khu-vuc-thu-mua/khu-vuc-mien-nam/">Thu Mua Phế Liệu Miền Nam</a></li>
                <li><a href="/khu-vuc-thu-mua/khu-vuc-toan-quoc/">Thu Mua Phế Liệu Giá Cao Toàn Quốc</a></li>
                <li><a href="/khu-vuc-thu-mua/khu-vuc-mien-trung/">Thu Mua Phế Liệu Miền Trung</a></li>
                <li><a href="/khu-vuc-thu-mua/khu-vuc-mien-bac/">Thu Mua Phế Liệu Miền Bắc</a></li>
              </ul>
            </li>
            <li><a href="/bang-gia/">Bảng Giá</a></li>
            <li><a href="/quy-trinh/">Quy Trình</a></li>
            <li><a href="/lien-he/">Liên Hệ</a></li>
            <li><a href="/tin-tuc/">Tin Tức</a></li>
          </ul>
        </nav>
        <button class="menu-icon" id="menu-icon"
          aria-label="Mở menu điều hướng"
          aria-expanded="false"
          aria-controls="nav-links">
          <div></div>
          <div></div>
          <div></div>
        </button>
      </div>
    </header>

    <div class="menu-overlay" id="menu-overlay"></div>

    <!-- Nội dung trang -->
    <slot />

    <!-- Footer -->
    <footer class="footer">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-col">
            <h4>Công Ty Thu Mua Cáp Đồng Đức Minh</h4>
            <p>Đơn vị hàng đầu chuyên thu mua vật tư công trình, thiết bị điện và phế liệu dự án giá cao, cam kết mang lại giá trị thu hồi tối đa cho đối tác.</p>
          </div>
          <div class="footer-col">
            <h4>Thông Tin Liên Hệ</h4>
            <ul>
              <li><strong>Địa chỉ:</strong> {settings.address}</li>
              <li><strong>Hotline:</strong> <a href={`tel:${settings.hotline}`}>{settings.hotlineDisplay}</a></li>
              <li><strong>Email:</strong> <a href="mailto:{settings.email}">{settings.email}</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Dịch Vụ Chính</h4>
            <ul>
              <li><a href="/thu-mua-cap-dong-thiet-bi-dien/">Thu mua cáp điện &amp; thiết bị điện</a></li>
              <li><a href="/thu-mua-pin-nang-luong-mat-troi/">Thu mua pin năng lượng mặt trời</a></li>
              <li><a href="/thu-mua-phe-lieu-cong-nghiep/">Thu mua phế liệu công nghiệp</a></li>
              <li><a href="/thu-mua-inox/">Thu mua Inox</a></li>
              <li><a href="/thu-mua-nhom/">Thu mua nhôm</a></li>
              <li><a href="/bang-gia/">Xem Bảng Giá Phế Liệu</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Bản Đồ</h4>
            <div class="map-container">
              <iframe
                title="Bản đồ chỉ đường đến Công ty Đức Minh"
                src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d15670.804260691722!2d106.636344!3d10.910308!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3174d70677247829%3A0xab4886d2a9b58705!2zQ8OUTkcgVFkgVEhVIE1VQSBQSOG6viBMSeG7hlUgxJDhu6hDIE1JTkg!5e0!3m2!1svi!2sus!4v1761935511970!5m2!1svi!2sus"
                width="600" height="450" style="border:0" allowfullscreen="" loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© <span id="year"></span> Bản quyền thuộc về Đức Minh. Thiết kế bởi MinhQuang.</p>
        <p style="margin-top:10px;font-size:0.85rem;color:#888;">
          Thu Mua Cáp Đồng Giá Cao là thương hiệu chuyên trách về mảng kim loại màu, trực thuộc hệ sinh thái của Tổng công ty
          <a href="https://www.capdongbactrungnam.com/" target="_blank" rel="noopener noreferrer" title="Tổng Công ty Cáp Điện Bắc Trung Nam" style="color:#0056b3;font-weight:bold;text-decoration:none;">Cáp Điện Bắc Trung Nam</a>
          - Đơn vị hàng đầu về thu mua phế liệu công nghiệp và tháo dỡ nhà xưởng toàn quốc.
        </p>
        <p style="margin-top:8px;font-size:0.82rem;color:#888;">
          <a href="/chinh-sach-bao-mat/" style="color:#888;">Chính Sách Bảo Mật</a>
        </p>
      </div>
    </footer>

    <!-- Main JS -->
    <script src="/script.js?v=2" defer></script>

    <!-- Custom Body Scripts từ CMS -->
    {settings.bodyScripts && <Fragment set:html={settings.bodyScripts} />}
  </body>
</html>
